generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// アップロード履歴
model Upload {
  id            Int     @id @default(autoincrement())
  filename      String
  uploadDate    DateTime @default(now())
  totalMessages Int
  activeUsers   Int
  chatMessages  ChatMessage[]
  createdAt     DateTime @default(now())
}

// チャットメッセージ（生データ）
model ChatMessage {
  id        Int     @id @default(autoincrement())
  uploadId  Int
  upload    Upload  @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  timestamp DateTime
  username  String
  message   String
  createdAt DateTime @default(now())

  @@index([uploadId])
}
